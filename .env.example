# Nexus Proxy — environment configuration
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Every variable has a sane default for local dev with Ollama, so you can
# leave most unset while you iterate.

# --- HTTP server ----------------------------------------------------------
NEXUS_ADDR=:8000

# --- Structured logging (issue #3) ---------------------------------------
# Minimum level for the structured stderr logger.
# One of: debug | info | warn | error. Default: info.
NEXUS_LOG_LEVEL=info
# Wire format for the structured stderr logger.
# One of: json | text. Default: json (set "text" for a friendlier local view).
NEXUS_LOG_FORMAT=json

# --- Local Ollama ---------------------------------------------------------
NEXUS_OLLAMA_URL=http://localhost:11434
NEXUS_ROUTER_MODEL=qwen3-coder:4b
NEXUS_LOCAL_MODEL=qwen3-coder:8b
NEXUS_EMBEDDING_MODEL=nomic-embed-text

# --- Frontier API (OpenAI-compatible) ------------------------------------
# Replace with a real key. When unset, frontier-bound requests will 401.
NEXUS_FRONTIER_URL=https://api.openai.com/v1/chat/completions
NEXUS_FRONTIER_MODEL=gpt-4o
NEXUS_FRONTIER_API_KEY=

# --- Cascade fallback (issue #14) ----------------------------------------
# Optional second fallback in the local-route cascade (frontier is tried
# first when its key is set). Leave NEXUS_ZAI_API_KEY empty to skip.
NEXUS_ZAI_URL=https://api.z.ai/v1/chat/completions
NEXUS_ZAI_MODEL=glm-4.6
NEXUS_ZAI_API_KEY=

# --- RAG ------------------------------------------------------------------
# Directory of golden code snippets; auto-created if missing.
NEXUS_EXAMPLES_DIR=./few_shot_examples
# Cosine similarity threshold (0.0-1.0) above which a few-shot is injected.
NEXUS_RAG_THRESHOLD=0.55

# --- Routing timeouts -----------------------------------------------------
# Estimated tokens above this force-route to frontier (VRAM guardrail).
NEXUS_TOKEN_GUARDRAIL=6000
NEXUS_SLM_TIMEOUT=8s
NEXUS_FUSION_TIMEOUT=120s

# Per-attempt timeout for cascade fallback members (each retry gets this long).
NEXUS_CASCADE_TIMEOUT=30s

# Per-call timeout for the fusion arbiter synthesis step (issue #12).
# Shorter than NEXUS_FUSION_TIMEOUT because the arbiter only does
# synthesis — a slow arbiter must not pin the whole request indefinitely.
NEXUS_ARBITER_TIMEOUT=60s

# --- Fusion progressive delivery (issue #48) --------------------------
# When true (default), route=fusion streams the first panel member
# to complete as a speculative OpenAI-compatible SSE chunk and only
# invokes the arbiter when the second member disagrees (similarity
# below NEXUS_FUSION_AGREEMENT_THRESHOLD). On agreement the user
# sees the faster member's answer in ~max(local, frontier) time with
# no arbiter cost. When false, the legacy blocking Panel is used:
# both members fetched, arbiter always invoked — full backward compat.
NEXUS_FUSION_PROGRESSIVE=true
# Jaccard similarity [0.0-1.0] above which the two panel members are
# considered to agree and the arbiter is skipped. Default 0.85 means
# "skip when >=85% of tokens overlap". Out-of-range values are clamped
# by upstream.PanelStreaming so a misconfigured operator cannot break
# the path entirely (negative -> always skip, >1 -> only identical).
NEXUS_FUSION_AGREEMENT_THRESHOLD=0.85

# --- Ollama health poller (issue #8) ------------------------------------
# Background poller that pings Ollama /api/tags and keeps a circuit
# breaker. When the local Ollama is unreachable the chat handler
# transparently reroutes RouteLocal to frontier (and skips the local
# panel member of RouteFusion) and stamps X-Nexus-Degraded: true on
# the response. Set NEXUS_HEALTH_POLL_INTERVAL to "0" to disable
# polling entirely (the handler then assumes local is always healthy).
NEXUS_HEALTH_POLL_INTERVAL=30s
# Consecutive failed probes before the breaker trips and the local
# route is treated as unhealthy. The breaker reopens on the next
# successful probe.
NEXUS_HEALTH_BREAKER_THRESHOLD=3
# Per-probe HTTP timeout. Probes that exceed this count as failures.
NEXUS_HEALTH_PROBE_TIMEOUT=5s

# --- Async LLM-as-a-Judge evaluator (issue #15) -------------------------
# Disabled when NEXUS_JUDGE_SAMPLE_RATE is <= 0. The judge is sent to an
# external frontier endpoint (never the local model — would OOM the 8 GB
# VRAM). Falls back to NEXUS_FRONTIER_URL when NEXUS_JUDGE_URL is empty.
NEXUS_JUDGE_URL=https://api.z.ai/v1/chat/completions
NEXUS_JUDGE_MODEL=gpt-4o
NEXUS_JUDGE_API_KEY=
# Fraction (0.0-1.0) of completed local-route requests that get graded.
NEXUS_JUDGE_SAMPLE_RATE=0.1
# Max simultaneous judge calls; keeps frontier rate-limit headroom.
NEXUS_JUDGE_CONCURRENCY=2
# Buffered queue size; enqueue is non-blocking and drops on overflow.
NEXUS_JUDGE_QUEUE=64
NEXUS_JUDGE_TIMEOUT=30s
# Rough USD per 1k tokens (input+output) used for cost estimates.
NEXUS_JUDGE_COST_PER_1K=0.002

# --- Telemetry ------------------------------------------------------------
# Path to the append-only JSON-lines log written by the background
# telemetry goroutine. Set to empty to disable recording entirely.
# Schema: one JSON object per line — see internal/telemetry.Record.
NEXUS_TELEMETRY_PATH=./nexus-telemetry.jsonl

# Path to the SQLite database that powers the savings dashboard
# (issue #4). One row per proxied request including route, model,
# input tokens, TOON savings, RAG injection, and estimated frontier
# cost — see internal/metrics for the schema. Set to empty to disable
# the metrics store entirely. Parent directories are created on demand.
NEXUS_METRICS_DB=~/.cache/nexus-proxy/metrics.db

# --- AST/compiler verifier (issue #13) ------------------------------------
# Detected file edits in upstream responses are enqueued for a background
# `cargo check` / `npx tsc` against the detected project root. Each
# verdict (1 = clean exit 0, 0 = any non-zero / timeout) is dispatched
# to the operator via the QualityObserver hook (see internal/quality).
# Set NEXUS_QUALITY_CONCURRENCY=0 to disable entirely; the chat hot path
# is unaffected.
NEXUS_QUALITY_CONCURRENCY=2
# Buffered queue size; enqueue is non-blocking and drops on overflow.
NEXUS_QUALITY_QUEUE=64
# Per-check timeout (cargo / tsc) — anything slower is scored as 0.
NEXUS_QUALITY_TIMEOUT=60s
# Stderr bytes retained per verdict (truncated from the tail).
NEXUS_QUALITY_STDERR_CAP=2048
# Test-only hook. When set, the verifier runs `/bin/sh -c <value>`
# inside the detected repo root instead of the real check command;
# exit code 0 -> Pass=true. Intended for unit tests; production
# deployments should leave this unset.
NEXUS_QUALITY_SHELL_OVERRIDE=
