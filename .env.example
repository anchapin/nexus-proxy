# Nexus Proxy — environment configuration
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Every variable has a sane default for local dev with Ollama, so you can
# leave most unset while you iterate.

# --- HTTP server ----------------------------------------------------------
NEXUS_ADDR=:8000

# --- TLS termination (issue #39) -----------------------------------------
# Optional TLS so inbound traffic is encrypted. When BOTH cert and key
# paths are set, the proxy uses ListenAndServeTLS instead of plain HTTP.
# Leave both unset for localhost dev — the proxy behaves identically to
# before (no breaking change). At boot the proxy logs a warning when
# inbound auth is enabled but TLS is not (API keys over plaintext).
#
# Point these at your cert/key files (e.g. Let's Encrypt, or a self-signed
# cert for testing). Both must be set together; setting only one is
# treated as "TLS inactive" so a half-configured deploy keeps serving.
NEXUS_TLS_CERT=
NEXUS_TLS_KEY=
# When true (alongside TLS active), start a second listener on :80 that
# issues a 301 Moved Permanently to the HTTPS port so plain-HTTP clients
# get upgraded. Accepted truthy values: true | 1 | yes | on.
NEXUS_TLS_REDIRECT=false

# --- Inbound proxy authentication (issue #37) ----------------------------
# Optional bearer-token gate for inbound requests. When at least one key
# is configured, /v1/chat/completions requires a valid
# `Authorization: Bearer <key>` or `X-API-Key` header or it returns 401
# with an OpenAI-compatible error envelope. /healthz stays exempt so
# orchestrator liveness probes work without a key.
#
# Leave BOTH unset for localhost dev — the proxy then behaves identically
# to today (no breaking change). At boot the proxy logs a warning if auth
# is disabled AND NEXUS_ADDR binds a non-loopback interface.
#
# Single key (simplest):
NEXUS_PROXY_API_KEY=
# Multiple comma-separated keys (zero-downtime rotation — any one is
# accepted; remove the old one from the list once clients have rotated):
NEXUS_PROXY_API_KEYS=

# --- Structured logging (issue #3) ---------------------------------------
# Minimum level for the structured stderr logger.
# One of: debug | info | warn | error. Default: info.
NEXUS_LOG_LEVEL=info
# Wire format for the structured stderr logger.
# One of: json | text. Default: json (set "text" for a friendlier local view).
NEXUS_LOG_FORMAT=json

# --- Local Ollama ---------------------------------------------------------
NEXUS_OLLAMA_URL=http://localhost:11434
NEXUS_ROUTER_MODEL=qwen3-coder:4b
NEXUS_LOCAL_MODEL=qwen3-coder:8b
NEXUS_EMBEDDING_MODEL=nomic-embed-text

# --- Frontier API (OpenAI-compatible) ------------------------------------
# Replace with a real key. When unset, frontier-bound requests will 401.
NEXUS_FRONTIER_URL=https://api.openai.com/v1/chat/completions
NEXUS_FRONTIER_MODEL=gpt-4o
NEXUS_FRONTIER_API_KEY=

# --- Cascade fallback (issue #14) ----------------------------------------
# Optional second fallback in the local-route cascade (frontier is tried
# first when its key is set). Leave NEXUS_ZAI_API_KEY empty to skip.
NEXUS_ZAI_URL=https://api.z.ai/v1/chat/completions
NEXUS_ZAI_MODEL=glm-4.6
NEXUS_ZAI_API_KEY=

# --- RAG ------------------------------------------------------------------
# Directory of golden code snippets; auto-created if missing.
NEXUS_EXAMPLES_DIR=./few_shot_examples
# Cosine similarity threshold (0.0-1.0) above which a few-shot is injected.
NEXUS_RAG_THRESHOLD=0.55

# --- Routing timeouts -----------------------------------------------------
# Estimated tokens above this force-route to frontier (VRAM guardrail).
NEXUS_TOKEN_GUARDRAIL=6000
NEXUS_SLM_TIMEOUT=8s
NEXUS_FUSION_TIMEOUT=120s

# Per-attempt timeout for cascade fallback members (each retry gets this long).
NEXUS_CASCADE_TIMEOUT=30s

# Per-call timeout for the fusion arbiter synthesis step (issue #12).
# Shorter than NEXUS_FUSION_TIMEOUT because the arbiter only does
# synthesis — a slow arbiter must not pin the whole request indefinitely.
NEXUS_ARBITER_TIMEOUT=60s

# --- VRAM-aware concurrency gate (issue #35) ----------------------------
# Caps the number of RouteLocal requests (and the local panel member of
# RouteFusion) that may dispatch local Ollama concurrently, so a herd
# of coding agents cannot collectively OOM the GPU. Waiters queue-and-
# wait up to NEXUS_LOCAL_QUEUE_TIMEOUT; on timeout the chat handler
# fast-promotes the request to frontier via the cascade skip-local
# knob and stamps X-Nexus-Overflow: true on the response. The frontier
# (RouteFrontier) route is never gated. Default of 2 is well below
# typical 8 GiB VRAM budgets; set to 0 to disable the gate entirely
# (unbounded, pre-issue-#35 behaviour).
NEXUS_LOCAL_MAX_CONCURRENT=2
# How long a request is willing to wait for a slot before being
# promoted to frontier. Anything <=0 collapses to "try once and give
# up", which is rarely useful outside tests; 5s matches the operator's
# tolerance for an interactive harness to land on local.
NEXUS_LOCAL_QUEUE_TIMEOUT=5s

# --- Ollama health poller (issue #8) ------------------------------------
# Background poller that pings Ollama /api/tags and keeps a circuit
# breaker. When the local Ollama is unreachable the chat handler
# transparently reroutes RouteLocal to frontier (and skips the local
# panel member of RouteFusion) and stamps X-Nexus-Degraded: true on
# the response. Set NEXUS_HEALTH_POLL_INTERVAL to "0" to disable
# polling entirely (the handler then assumes local is always healthy).
NEXUS_HEALTH_POLL_INTERVAL=30s
# Consecutive failed probes before the breaker trips and the local
# route is treated as unhealthy. The breaker reopens on the next
# successful probe.
NEXUS_HEALTH_BREAKER_THRESHOLD=3
# Per-probe HTTP timeout. Probes that exceed this count as failures.
NEXUS_HEALTH_PROBE_TIMEOUT=5s

# --- Async LLM-as-a-Judge evaluator (issue #15) -------------------------
# Disabled when NEXUS_JUDGE_SAMPLE_RATE is <= 0. The judge is sent to an
# external frontier endpoint (never the local model — would OOM the 8 GB
# VRAM). Falls back to NEXUS_FRONTIER_URL when NEXUS_JUDGE_URL is empty.
NEXUS_JUDGE_URL=https://api.z.ai/v1/chat/completions
NEXUS_JUDGE_MODEL=gpt-4o
NEXUS_JUDGE_API_KEY=
# Fraction (0.0-1.0) of completed local-route requests that get graded.
NEXUS_JUDGE_SAMPLE_RATE=0.1
# Max simultaneous judge calls; keeps frontier rate-limit headroom.
NEXUS_JUDGE_CONCURRENCY=2
# Buffered queue size; enqueue is non-blocking and drops on overflow.
NEXUS_JUDGE_QUEUE=64
NEXUS_JUDGE_TIMEOUT=30s
# Rough USD per 1k tokens (input+output) used for cost estimates.
NEXUS_JUDGE_COST_PER_1K=0.002

# --- Telemetry ------------------------------------------------------------
# Path to the append-only JSON-lines log written by the background
# telemetry goroutine. Set to empty to disable recording entirely.
# Schema: one JSON object per line — see internal/telemetry.Record.
NEXUS_TELEMETRY_PATH=./nexus-telemetry.jsonl

# Path to the SQLite database that powers the savings dashboard
# (issue #4). One row per proxied request including route, model,
# input tokens, TOON savings, RAG injection, and estimated frontier
# cost — see internal/metrics for the schema. Set to empty to disable
# the metrics store entirely. Parent directories are created on demand.
NEXUS_METRICS_DB=~/.cache/nexus-proxy/metrics.db

# --- AST/compiler verifier (issue #13) ------------------------------------
# Detected file edits in upstream responses are enqueued for a background
# `cargo check` / `npx tsc` against the detected project root. Each
# verdict (1 = clean exit 0, 0 = any non-zero / timeout) is dispatched
# to the operator via the QualityObserver hook (see internal/quality).
# Set NEXUS_QUALITY_CONCURRENCY=0 to disable entirely; the chat hot path
# is unaffected.
NEXUS_QUALITY_CONCURRENCY=2
# Buffered queue size; enqueue is non-blocking and drops on overflow.
NEXUS_QUALITY_QUEUE=64
# Per-check timeout (cargo / tsc) — anything slower is scored as 0.
NEXUS_QUALITY_TIMEOUT=60s
# Stderr bytes retained per verdict (truncated from the tail).
NEXUS_QUALITY_STDERR_CAP=2048
# Test-only hook. When set, the verifier runs `/bin/sh -c <value>`
# inside the detected repo root instead of the real check command;
# exit code 0 -> Pass=true. Intended for unit tests; production
# deployments should leave this unset.
NEXUS_QUALITY_SHELL_OVERRIDE=

# --- HTTP connection pool (issue #34) --------------------------------------
# Every outbound call — chat upstream, SLM routing, RAG embedding, health
# polling, VRAM probing, the judge evaluator — shares a single
# *http.Client wired with a custom *http.Transport sized for a multi-agent
# local development workload. The Go stdlib default (MaxIdleConnsPerHost=2)
# is the very bottleneck this fixes; raise the per-host idle cap so the
# chat handler + SLM + RAG goroutines can all hit the local Ollama without
# fighting for two idle conns.
NEXUS_HTTP_MAX_IDLE_CONNS=100
# Idle conns retained per host. Default 16 is plenty for a chat handler
# plus a few background pollers; raise for higher-fanout workloads.
NEXUS_HTTP_MAX_IDLE_CONNS_PER_HOST=16
# Total (in-flight + idle) conns per host. 0 == unlimited, which matches
# the stdlib default and is fine for local Ollama. Set this when the
# upstream is a rate-limited public API.
NEXUS_HTTP_MAX_CONNS_PER_HOST=0
# How long an idle connection stays in the pool before being closed.
NEXUS_HTTP_IDLE_CONN_TIMEOUT=90s
# Disable HTTP keep-alive. The pool is pointless without keep-alive, so
# this stays off unless an upstream has a known broken Connection: close
# behaviour. Accepted truthy values: true | 1 | yes | on.
NEXUS_HTTP_DISABLE_KEEPALIVES=false

# --- Rate limiting + daily budget (issue #38) ----------------------------
# Stdlib-only token-bucket rate limiter. Per-client-IP buckets cap a
# single runaway client; the optional global bucket caps aggregate
# traffic across all clients. All values default to 0 (disabled) —
# the proxy behaves identically to before when nothing is configured.
#
# Per-client requests per minute. 0 disables the per-client limiter.
NEXUS_RATE_LIMIT_RPM=0
# Per-client burst capacity (token bucket size). 0 defaults to RPM,
# giving a fresh client a full minute's worth of requests up front.
NEXUS_RATE_LIMIT_BURST=0
# Aggregate RPM across all clients. 0 disables the global limiter.
# Checked BEFORE the per-client bucket so a herd of clients cannot
# collectively exceed the global ceiling.
NEXUS_GLOBAL_RATE_LIMIT_RPM=0
# Rolling 24-hour spend cap for RouteFrontier requests (USD). 0
# disables the budget gate. When the trailing 24h frontier spend
# exceeds this cap, frontier requests return 429 "Daily frontier
# budget exceeded" — local routing still works. Uses the
# NEXUS_JUDGE_COST_PER_1K rate for cost estimation.
NEXUS_FRONTIER_DAILY_BUDGET_USD=0

# --- Distributed tracing (issue #41) --------------------------------------
# W3C Trace Context propagation + OTLP/JSON export. Leave the endpoint
# empty (the default) to disable tracing entirely — no background
# goroutine, no per-request allocation beyond a nil-check. Setting the
# endpoint starts a buffered, async POST loop to your collector (Tempo,
# Jaeger, OTel Collector, ...). Inbound W3C `traceparent` headers are
# honoured so an upstream caller can attach the proxy to its trace;
# outbound upstream calls (Ollama, frontier, fusion panel) also carry
# `traceparent` for distributed correlation.
#
# Example collector URL:
#   http://localhost:4318/v1/traces
NEXUS_TRACING_ENDPOINT=
# Probability (0.0–1.0) that any given request is recorded. 0 disables
# sampling (effectively the same as leaving the endpoint empty — no
# spans are exported). 1.0 records every request. The decision is
# hashed on the trace id so multiple replicas agree on which traces to
# record.
NEXUS_TRACING_SAMPLE_RATE=0
# Per-POST timeout for the OTLP/JSON collector. A stalled collector
# does NOT block the request path — the export is async and uses a
# buffered channel — but a slow collector consumes a worker briefly.
NEXUS_TRACING_TIMEOUT=10s
# Buffered channel size for in-flight spans. When the buffer fills
# (collector stalled or fatal write error) additional spans are dropped
# with a warning rather than stalling user requests. Default 256 is
# ~256 KB worst-case memory.
NEXUS_TRACING_QUEUE=256
